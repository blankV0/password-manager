# ═════════════════════════════════════════════════════════════════════════════
# .env.example — Template de variáveis de ambiente
# ─────────────────────────────────────────────────────────────────────────────
#
# INSTRUÇÕES:
#   1. Copiar este ficheiro: cp .env.example .env
#   2. Preencher TODOS os valores marcados com <CHANGE_ME>
#   3. Gerar secrets seguros: python docker/deploy/generate_secrets.py
#   4. NUNCA commitar o .env real no git (já está no .gitignore)
#
# ═════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# AMBIENTE
# production → desativa /docs, /redoc; valida que JWT_SECRET não é o default
# development → ativa /docs, permite JWT_SECRET fraco
# ─────────────────────────────────────────────────────────────────────────────
APP_ENV=production

# ─────────────────────────────────────────────────────────────────────────────
# SEGREDO JWT
# CRÍTICO: mudar para um valor aleatório de 512 bits.
# Gerar com: python docker/deploy/generate_secrets.py
# Se este valor for comprometido, TODOS os tokens emitidos ficam inválidos.
# ─────────────────────────────────────────────────────────────────────────────
AUTH_JWT_SECRET=<CHANGE_ME>

# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DADOS
# Path dentro do container Docker — não alterar a menos que saibas o que fazes
# ─────────────────────────────────────────────────────────────────────────────
AUTH_DB_PATH=/app/data/auth.db

# ─────────────────────────────────────────────────────────────────────────────
# TOKENS
# ─────────────────────────────────────────────────────────────────────────────
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_TTL_SECONDS=900        # 15 minutos
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800    # 7 dias

# ─────────────────────────────────────────────────────────────────────────────
# ISSUER / AUDIENCE
# Mudar para o teu hostname real (ex: hostname Tailscale ou domínio)
# ─────────────────────────────────────────────────────────────────────────────
AUTH_ISSUER=password-manager-auth
AUTH_AUDIENCE=password-manager-clients

# ─────────────────────────────────────────────────────────────────────────────
# PROTECÇÃO DE CONTA
# ─────────────────────────────────────────────────────────────────────────────
AUTH_LOGIN_MAX_FAILURES=5          # Tentativas antes de lock
AUTH_LOGIN_LOCKOUT_SECONDS=900     # 15 minutos de lock

# ─────────────────────────────────────────────────────────────────────────────
# RATE LIMITING (in-memory, por IP)
# ─────────────────────────────────────────────────────────────────────────────
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10

# ─────────────────────────────────────────────────────────────────────────────
# POLITICA DE PASSWORDS
# ─────────────────────────────────────────────────────────────────────────────
AUTH_PASSWORD_MIN_LENGTH=12

# ─────────────────────────────────────────────────────────────────────────────
# LOGS
# ─────────────────────────────────────────────────────────────────────────────
AUTH_LOG_FILE=/app/logs/auth.log

# ─────────────────────────────────────────────────────────────────────────────
# APP DESKTOP — URL do servidor de autenticação
# A app desktop usa esta variável para se ligar ao servidor.
# Preencher com o IP Tailscale (ou domínio) onde o servidor corre.
# Obter o IP Tailscale do servidor com: tailscale ip -4
# ─────────────────────────────────────────────────────────────────────────────
API_BASE_URL=https://<TAILSCALE_IP_DO_SERVIDOR>

# ─────────────────────────────────────────────────────────────────────────────
# TAILSCALE (opcional — só necessário se usares binding por IP)
# Obter com: tailscale ip -4
# ─────────────────────────────────────────────────────────────────────────────
# TAILSCALE_IP=100.x.x.x
